# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Security
ADMIN_KEY=your-secure-admin-token

# Storj DCS (S3 Compatible Storage)
STORJ_ACCESS_KEY=your-access-key
STORJ_SECRET_KEY=your-secret-key
STORJ_ENDPOINT=https://gateway.storjshare.io
STORJ_BUCKET=civicmap

# AI Providers (At least one required for news scraping)
GROQ_API_KEYS=gsk_xxx,gsk_yyy
OPENROUTER_API_KEYS=sk-or-v1-xxx
